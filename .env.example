# Keep the app private behind nginx, Caddy, Traefik, or a tunnel by default.
# Use 0.0.0.0 only when the port must be reachable directly from the network.
YOUPLANNER_BIND_ADDRESS=127.0.0.1
YOUPLANNER_PORT=4174

# Optional image and persistent Docker volume names.
YOUPLANNER_IMAGE=youplanner:latest
YOUPLANNER_DATA_VOLUME=youplanner-data
